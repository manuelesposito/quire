{
  "color": {
    "text": {
      "default":     { "$value": "#F4F4F5", "$type": "color" },
      "muted":       { "$value": "#A1A1AA", "$type": "color" },
      "subtle":      { "$value": "#85858D", "$type": "color" },
      "placeholder": { "$value": "#71717A", "$type": "color" },
      "inverse":     { "$value": "#0A0A0B", "$type": "color" },
      "accent":      { "$value": "#F4F4F5", "$type": "color" },
      "on-accent":   { "$value": "#0A0A0B", "$type": "color" }
    },
    "surface": {
      "canvas":  { "$value": "#0A0A0B", "$type": "color" },
      "raised":  { "$value": "#111113", "$type": "color" },
      "nav":     { "$value": "#111113", "$type": "color" },
      "sunken":  { "$value": "#1B1B1F", "$type": "color" },
      "inverse": { "$value": "#F4F4F5", "$type": "color" }
    },
    "border": {
      "default": { "$value": "#26262B", "$type": "color" },
      "strong":  { "$value": "#3F3F46", "$type": "color" }
    },
    "accent": {
      "soft":    { "$value": "#1B1B1F", "$type": "color" },
      "default": { "$value": "#F4F4F5", "$type": "color" },
      "strong":  { "$value": "#F4F4F5", "$type": "color" },
      "deep":    { "$value": "{color.white}", "$type": "color" }
    },
    "action": {
      "primary": {
        "default": { "$value": "#F4F4F5", "$type": "color" },
        "hover":   { "$value": "{color.white}", "$type": "color" },
        "text":    { "$value": "#0A0A0B", "$type": "color" }
      },
      "secondary": {
        "border": { "$value": "#3F3F46", "$type": "color" },
        "text":   { "$value": "#F4F4F5", "$type": "color" }
      },
      "tertiary": {
        "text": { "$value": "#F4F4F5", "$type": "color" }
      },
      "destructive": {
        "default": { "$value": "{color.red.600}", "$type": "color" },
        "hover":   { "$value": "{color.red.700}", "$type": "color" }
      }
    },
    "state": {
      "hover":            { "$value": "#FFFFFF0F", "$type": "color" },
      "active-surface":   { "$value": "#26262B", "$type": "color" },
      "selected-surface": { "$value": "#26262B", "$type": "color" },
      "selected-mark":    { "$value": "#F4F4F5", "$type": "color" },
      "focus-ring":       { "$value": "#F4F4F5", "$type": "color" }
    },
    "control": {
      "on":    { "$value": "#F4F4F5", "$type": "color" },
      "on-fg": { "$value": "#0A0A0B", "$type": "color" }
    },
    "feedback": {
      "success": {
        "surface": { "$value": "#111113", "$type": "color" },
        "chip":    { "$value": "#1B1B1F", "$type": "color" },
        "text":    { "$value": "{color.green.300}", "$type": "color" }
      },
      "warning": {
        "surface": { "$value": "#111113", "$type": "color" },
        "chip":    { "$value": "#1B1B1F", "$type": "color" },
        "text":    { "$value": "{color.amber.300}", "$type": "color" }
      },
      "danger": {
        "surface": { "$value": "#111113", "$type": "color" },
        "chip":    { "$value": "#1B1B1F", "$type": "color" },
        "text":    { "$value": "{color.red.300}", "$type": "color" }
      },
      "info": {
        "surface": { "$value": "#111113", "$type": "color" },
        "chip":    { "$value": "#1B1B1F", "$type": "color" },
        "text":    { "$value": "{color.blue.300}", "$type": "color" }
      }
    },
    "overlay": {
      "scrim": { "$value": "#00000099", "$type": "color" }
    }
  }
}
