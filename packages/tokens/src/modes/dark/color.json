{
  "color": {
    "text": {
      "default":     { "$value": "#F5F5F5", "$type": "color" },
      "muted":       { "$value": "#A1A1A1", "$type": "color" },
      "subtle":      { "$value": "#858585", "$type": "color" },
      "placeholder": { "$value": "#6F6F6F", "$type": "color" },
      "inverse":     { "$value": "#0A0A0A", "$type": "color" },
      "accent":      { "$value": "#F5F5F5", "$type": "color" },
      "on-accent":   { "$value": "#0A0A0A", "$type": "color" }
    },
    "surface": {
      "canvas":  { "$value": "#0A0A0A", "$type": "color" },
      "raised":  { "$value": "#111111", "$type": "color" },
      "nav":     { "$value": "#111111", "$type": "color" },
      "sunken":  { "$value": "#1B1B1B", "$type": "color" },
      "inverse": { "$value": "#F5F5F5", "$type": "color" }
    },
    "border": {
      "default": { "$value": "#262626", "$type": "color" },
      "strong":  { "$value": "#3F3F3F", "$type": "color" }
    },
    "accent": {
      "soft":    { "$value": "#1B1B1B", "$type": "color" },
      "default": { "$value": "#F5F5F5", "$type": "color" },
      "strong":  { "$value": "#F5F5F5", "$type": "color" },
      "deep":    { "$value": "{color.white}", "$type": "color" }
    },
    "action": {
      "primary": {
        "default": { "$value": "#F5F5F5", "$type": "color" },
        "hover":   { "$value": "{color.white}", "$type": "color" },
        "text":    { "$value": "#0A0A0A", "$type": "color" }
      },
      "secondary": {
        "border": { "$value": "#3F3F3F", "$type": "color" },
        "text":   { "$value": "#F5F5F5", "$type": "color" }
      },
      "tertiary": {
        "text": { "$value": "#F5F5F5", "$type": "color" }
      },
      "destructive": {
        "default": { "$value": "{color.red.600}", "$type": "color" },
        "hover":   { "$value": "{color.red.700}", "$type": "color" }
      }
    },
    "state": {
      "hover":            { "$value": "#FFFFFF0F", "$type": "color" },
      "active-surface":   { "$value": "#262626", "$type": "color" },
      "selected-surface": { "$value": "#262626", "$type": "color" },
      "selected-mark":    { "$value": "#F5F5F5", "$type": "color" },
      "focus-ring":       { "$value": "#F5F5F5", "$type": "color" }
    },
    "control": {
      "on":    { "$value": "#F5F5F5", "$type": "color" },
      "on-fg": { "$value": "#0A0A0A", "$type": "color" }
    },
    "feedback": {
      "success": {
        "surface": { "$value": "#111111", "$type": "color" },
        "chip":    { "$value": "#1B1B1B", "$type": "color" },
        "text":     { "$value": "{color.green.300}", "$type": "color" },
        "default":  { "$value": "{color.green.700}", "$type": "color" },
        "hover":    { "$value": "{color.green.800}", "$type": "color" },
        "pressed":  { "$value": "{color.green.900}", "$type": "color" },
        "on-solid": { "$value": "{color.white}", "$type": "color" }
      },
      "warning": {
        "surface": { "$value": "#111111", "$type": "color" },
        "chip":    { "$value": "#1B1B1B", "$type": "color" },
        "text":     { "$value": "{color.amber.300}", "$type": "color" },
        "default":  { "$value": "{color.amber.600}", "$type": "color" },
        "hover":    { "$value": "{color.amber.700}", "$type": "color" },
        "pressed":  { "$value": "{color.amber.900}", "$type": "color" },
        "on-solid": { "$value": "{color.white}", "$type": "color" }
      },
      "danger": {
        "surface": { "$value": "#111111", "$type": "color" },
        "chip":    { "$value": "#1B1B1B", "$type": "color" },
        "text":     { "$value": "{color.red.300}", "$type": "color" },
        "default":  { "$value": "{color.red.700}", "$type": "color" },
        "hover":    { "$value": "{color.red.800}", "$type": "color" },
        "pressed":  { "$value": "{color.red.900}", "$type": "color" },
        "on-solid": { "$value": "{color.white}", "$type": "color" }
      },
      "info": {
        "surface": { "$value": "#111111", "$type": "color" },
        "chip":    { "$value": "#1B1B1B", "$type": "color" },
        "text":     { "$value": "{color.blue.300}", "$type": "color" },
        "default":  { "$value": "{color.blue.700}", "$type": "color" },
        "hover":    { "$value": "{color.blue.800}", "$type": "color" },
        "pressed":  { "$value": "{color.blue.900}", "$type": "color" },
        "on-solid": { "$value": "{color.white}", "$type": "color" }
      }
    },
    "overlay": {
      "scrim": { "$value": "#00000099", "$type": "color" }
    }
  }
}
