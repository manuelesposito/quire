{
  "space": {
    "0":   { "$value": "0",    "$type": "dimension" },
    "100": { "$value": "4px",  "$type": "dimension" },
    "200": { "$value": "8px",  "$type": "dimension" },
    "300": { "$value": "12px", "$type": "dimension" },
    "400": { "$value": "16px", "$type": "dimension" },
    "600": { "$value": "24px", "$type": "dimension" }
  },
  "radius": {
    "none": { "$value": "0",      "$type": "dimension" },
    "200":  { "$value": "6px",    "$type": "dimension" },
    "300":  { "$value": "8px",    "$type": "dimension" },
    "full": { "$value": "9999px", "$type": "dimension" }
  },
  "font": {
    "size": {
      "100": { "$value": "12px", "$type": "dimension" },
      "200": { "$value": "14px", "$type": "dimension" },
      "300": { "$value": "16px", "$type": "dimension" },
      "500": { "$value": "20px", "$type": "dimension" },
      "700": { "$value": "28px", "$type": "dimension" }
    },
    "weight": {
      "regular":  { "$value": "400", "$type": "fontWeight" },
      "medium":   { "$value": "500", "$type": "fontWeight" },
      "semibold": { "$value": "600", "$type": "fontWeight" }
    }
  }
}
