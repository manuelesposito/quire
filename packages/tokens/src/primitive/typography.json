{
  "font": {
    "family": {
      "serif": { "$value": "Newsreader, Georgia, serif", "$type": "fontFamily" },
      "sans":  { "$value": "Inter, system-ui, sans-serif", "$type": "fontFamily" },
      "mono":  { "$value": "'IBM Plex Mono', ui-monospace, monospace", "$type": "fontFamily" }
    },
    "weight": {
      "regular":  { "$value": "400", "$type": "fontWeight" },
      "medium":   { "$value": "500", "$type": "fontWeight" },
      "semibold": { "$value": "600", "$type": "fontWeight" },
      "bold":     { "$value": "700", "$type": "fontWeight" }
    },
    "size": {
      "100": { "$value": "11px", "$type": "dimension" },
      "200": { "$value": "12px", "$type": "dimension" },
      "300": { "$value": "13px", "$type": "dimension" },
      "400": { "$value": "14px", "$type": "dimension" },
      "500": { "$value": "16px", "$type": "dimension" },
      "600": { "$value": "18px", "$type": "dimension" },
      "700": { "$value": "22px", "$type": "dimension" },
      "800": { "$value": "28px", "$type": "dimension" },
      "900": { "$value": "40px", "$type": "dimension" }
    },
    "line-height": {
      "tight":   { "$value": "1.1",  "$type": "number" },
      "snug":    { "$value": "1.3",  "$type": "number" },
      "normal":  { "$value": "1.45", "$type": "number" },
      "relaxed": { "$value": "1.6",  "$type": "number" }
    },
    "letter-spacing": {
      "tight":  { "$value": "-0.015em", "$type": "dimension" },
      "normal": { "$value": "-0.006em", "$type": "dimension" },
      "wide":   { "$value": "0.14em",   "$type": "dimension" }
    }
  }
}
